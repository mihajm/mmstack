{
  "compilerOptions": {
    "rootDir": ".",
    "isolatedModules": true,
    "sourceMap": true,
    "declaration": false,
    "verbatimModuleSyntax": true,
    "experimentalDecorators": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "emitDecoratorMetadata": false,
    "importHelpers": true,
    "target": "es2025",
    "moduleResolution": "bundler",
    "module": "preserve",
    "lib": ["esnext", "dom"],
    "skipLibCheck": true,
    "paths": {
      "@mmstack/form-adapters": ["./packages/form/adapters/src/index.ts"],
      "@mmstack/form-core": ["./packages/form/core/src/index.ts"],
      "@mmstack/form-material": ["./packages/form/material/src/index.ts"],
      "@mmstack/form-validation": ["./packages/form/validation/src/index.ts"],
      "@mmstack/local": ["./packages/local/src/index.ts"],
      "@mmstack/primitives": ["./packages/primitives/src/index.ts"],
      "@mmstack/resource": ["./packages/resource/src/index.ts"],
      "@mmstack/router-core": ["./packages/router/core/src/index.ts"],
      "@mmstack/translate": ["./packages/translate/src/index.ts"],
      "@mmstack/di": ["./packages/di/src/index.ts"],
      "@mmstack/dnd": ["./packages/dnd/src/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "strictStandalone": true,
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "exclude": ["node_modules", "tmp"]
}
